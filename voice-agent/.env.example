# Voice Agent microservice environment variables
# Copy to .env and fill in values

# Internal API auth
VOICE_AGENT_API_KEY=generate-a-long-random-secret-here

# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_api_secret_here

# AI
OPENAI_API_KEY=sk-proj-xxxxxxxx
SARVAM_API_KEY=sk_xxxxxxxx

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Supabase S3 (recordings)
SUPABASE_S3_ACCESS_KEY=your_s3_access_key
SUPABASE_S3_SECRET_KEY=your_s3_secret_key
SUPABASE_S3_ENDPOINT=https://your-project.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-south-1

# SIP / Vobiz
VOBIZ_SIP_DOMAIN=your_domain.sip.vobiz.ai
VOBIZ_USERNAME=your_username
VOBIZ_PASSWORD=your_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX

# Telegram
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# Optional
# SENTRY_DSN=https://xxx@sentry.io/xxx
# N8N_WEBHOOK_URL=https://your-n8n.cloud/webhook/xxx
# CORS_ORIGINS=http://localhost:3000
