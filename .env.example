# ================================================================
# Unified AI CRM SaaS — Combined Environment Variables
# Copy this to .env and fill in your values.
# ================================================================

# ── Supabase (shared by both apps) ─────────────────────────────
# From: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── WhatsApp (wacrm) ───────────────────────────────────────────
# AES-256-GCM encryption key (64 hex chars):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-key-here

# Meta App Secret (Meta for Developers → App Settings → Basic)
META_APP_SECRET=your-meta-app-secret

# Public URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── Voice Agent (Python microservice) ─────────────────────────
# Internal secret — Next.js uses this to call the Python API
VOICE_AGENT_URL=http://voice-agent:8001
VOICE_AGENT_API_KEY=generate-a-long-random-secret-here

# ── LiveKit Cloud ──────────────────────────────────────────────
# From: https://cloud.livekit.io → your project → Settings
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_api_secret_here

# ── AI Providers ───────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional:
# ANTHROPIC_API_KEY=sk-ant-...  (for Claude LLM)
# GROQ_API_KEY=gsk_...         (for Groq LLM)

# ── SIP / Vobiz ────────────────────────────────────────────────
VOBIZ_SIP_DOMAIN=your_domain.sip.vobiz.ai
VOBIZ_USERNAME=your_username
VOBIZ_PASSWORD=your_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX

# ── Telegram Notifications ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# ── Supabase S3 (call recordings) ─────────────────────────────
SUPABASE_S3_ACCESS_KEY=your_supabase_s3_access_key
SUPABASE_S3_SECRET_KEY=your_supabase_s3_secret_key
SUPABASE_S3_ENDPOINT=https://your-project.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-south-1

# ── Optional ───────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/xxx
# N8N_WEBHOOK_URL=https://your-n8n.cloud/webhook/xxx
# AUTOMATION_CRON_SECRET=your-cron-secret
# CORS_ORIGINS=https://your-domain.com
